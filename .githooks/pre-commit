#!/bin/bash
# Mycelium pre-commit nag.
#
# If you're committing >100 lines of *production code* (not docs, not LOG.md,
# not data), prompt to run /review in Cursor first. Doesn't block — just nags.
#
# Install:
#   git config core.hooksPath .githooks

# Sum lines added+deleted in code files only
CODE_LOC=$(git diff --cached --numstat -- \
    '*.py' '*.ts' '*.tsx' '*.js' '*.jsx' '*.go' '*.rs' '*.java' '*.cpp' '*.c' '*.h' \
    2>/dev/null | awk '{s+=$1+$2} END {print s+0}')

if [ "${CODE_LOC:-0}" -gt 100 ]; then
    cat <<EOF >&2

────────────────────────────────────────────────────────────
  Mycelium nag: this commit changes ${CODE_LOC} lines of code.
  Consider running '/review' in Cursor before pushing.
  (Press Enter to commit anyway, Ctrl-C to abort and review.)
────────────────────────────────────────────────────────────
EOF
    # Read from /dev/tty so this works inside `git commit`
    if [ -t 0 ] || [ -e /dev/tty ]; then
        read -r _ < /dev/tty || true
    fi
fi

exit 0
