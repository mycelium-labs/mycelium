{
  "id": "langchain-36984",
  "source_url": "https://github.com/langchain-ai/langchain/issues/36984",
  "source_title": "Duplicate tool_calls in content_blocks with OpenAI Responses API streaming",
  "component": "MessageValidator",
  "pattern": "LangChain streaming leaves fc_* partial tool calls alongside final call_* IDs in the same assistant message. OpenAI then rejects: No tool output found for function call fc_xxx.",
  "violation": "duplicate_tool_call_blocks",
  "repairable": true,
  "messages": [
    {
      "role": "user",
      "content": "What's the weather in Boston and NYC?"
    },
    {
      "role": "assistant",
      "content": "",
      "tool_calls": [
        {
          "id": "fc_weather_boston",
          "type": "function",
          "index": 0,
          "function": {
            "name": "get_weather",
            "arguments": ""
          }
        },
        {
          "id": "call_weather_boston",
          "type": "function",
          "index": 0,
          "function": {
            "name": "get_weather",
            "arguments": "{\"city\": \"Boston\"}"
          }
        },
        {
          "id": "fc_weather_nyc",
          "type": "function",
          "index": 1,
          "function": {
            "name": "get_weather",
            "arguments": ""
          }
        },
        {
          "id": "call_weather_nyc",
          "type": "function",
          "index": 1,
          "function": {
            "name": "get_weather",
            "arguments": "{\"city\": \"NYC\"}"
          }
        }
      ]
    },
    {
      "role": "tool",
      "tool_call_id": "call_weather_boston",
      "content": "{\"temp_f\": 72, \"condition\": \"sunny\"}"
    },
    {
      "role": "tool",
      "tool_call_id": "call_weather_nyc",
      "content": "{\"temp_f\": 68, \"condition\": \"cloudy\"}"
    }
  ]
}
