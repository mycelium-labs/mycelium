# Copy to `.env` and fill in. Real `.env` is gitignored.
#
# Classifier: prefer Groq (cheap). If both GROQ and Anthropic keys exist,
# set LLM_BACKEND=groq or anthropic to choose.

GROQ_API_KEY=
LLM_BACKEND=groq
GROQ_MODEL=llama-3.1-8b-instant

# Optional: Anthropic when not using Groq
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5

HF_TOKEN=
MYCELIUM_HF_REPO=ndileep/mycelium-agent-failures
